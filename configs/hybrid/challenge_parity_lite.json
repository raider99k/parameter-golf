{
  "run": {
    "id": "challenge_parity_lite",
    "stage": "proxy"
  },
  "data": {
    "val_tokens_limit": 131072
  },
  "experts": {
    "enable_ngram": false,
    "enable_pointer": false,
    "enable_doc_bias": false
  },
  "adaptation": {
    "meta_enabled": false,
    "strict_commit_steps": 0,
    "exploratory_prefix_steps": 0,
    "exploratory_persist_across_docs": false
  },
  "eval": {
    "policy": "strict_causal",
    "score_tokens": 1024,
    "adapt_tokens": 3072,
    "window_tokens": 0,
    "documentwise": false,
    "adaptive_extra_pass": false,
    "write_block_logs": false
  },
  "export": {
    "write_after_train": true,
    "artifact_budget_bytes": 16000000,
    "budget_mode": "submission_total",
    "quant_scheme": "mixed_v1",
    "keep_float_policy": "small_and_control",
    "fail_if_over_budget": true
  }
}
